{
	"name": "examples.liforma.ai",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && simple-git-hooks",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"verify:commit": "npm run check && npm run lint",
		"verify": "npm run verify:commit && npm run build"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.9.3",
		"eslint": "^9.39.4",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^16.5.0",
		"simple-git-hooks": "^2.13.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "^1.4.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^8.0.16"
	},
	"simple-git-hooks": {
		"pre-commit": "npm run verify:commit"
	}
}
