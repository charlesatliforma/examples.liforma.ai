{
	"name": "spanish-tutor-sveltekit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint .",
		"verify:commit": "npm run check && npm run lint",
		"verify": "npm run verify:commit && npm run build"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.9.3",
		"eslint": "^9.39.4",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^16.5.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "^1.4.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^8.0.16"
	}
}
